PORT=5000
NODE_ENV=development

# Database Settings (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=spbklu_db

# Google OAuth Credentials
GOOGLE_CLIENT_ID=58586788358-f5b1ig0vnnmp34mudo6j6ftrcmr00n0k.apps.googleusercontent.com

# JWT Configuration
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Pakasir QRIS Payment Gateway (Backend only - do not expose API key to frontend)
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PROJECT_SLUG=spbklu
PAKASIR_API_KEY=your_pakasir_api_key_here
PAKASIR_WEBHOOK_VERIFY=true

# Battery swap payment
SWAP_COST=10000

# Optional: used to generate Pakasir redirect URL after payment
USER_APP_URL=http://localhost:5173
